{
  "id": null,
  "uid": "rescuecoord-overview",
  "title": "RescueCoord Services Overview",
  "tags": ["rescuecoord", "microservices"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Coordination — всего запросов",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(http_requests_total{job=\"coordination_service\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Monitoring — всего запросов",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(http_requests_total{job=\"monitoring_service\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx ошибок (последние 5 мин)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "4xx ошибок (последние 5 мин)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(increase(http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate (req/s) по сервисам",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"coordination_service\"}[1m]))",
          "legendFormat": "coordination-service"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"monitoring_service\"}[1m]))",
          "legendFormat": "monitoring-service"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Доля ошибок (4xx + 5xx)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [{ "matcher": { "id": "byName", "options": "coordination-service" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"coordination_service\",status=~\"[45]..\"}[1m])) / sum(rate(http_requests_total{job=\"coordination_service\"}[1m]))",
          "legendFormat": "coordination-service"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"monitoring_service\",status=~\"[45]..\"}[1m])) / sum(rate(http_requests_total{job=\"monitoring_service\"}[1m]))",
          "legendFormat": "monitoring-service"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 — Coordination Service",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"coordination_service\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"coordination_service\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"coordination_service\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 — Monitoring Service",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"monitoring_service\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"monitoring_service\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"monitoring_service\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP статус-коды — Coordination Service",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"coordination_service\"}[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP статус-коды — Monitoring Service",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"monitoring_service\"}[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Top-10 хендлеров по частоте — Coordination Service",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "topk(10, sum(rate(http_requests_total{job=\"coordination_service\"}[1m])) by (handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Top-10 хендлеров по частоте — Monitoring Service",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "topk(10, sum(rate(http_requests_total{job=\"monitoring_service\"}[1m])) by (handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    }
  ]
}
